    {
      "id": "dWC2NE4crsEVfbOrTEwkO",
      "type": "text",
      "x": 61.70320147936138,
      "y": 3.5551495123643804,
      "width": 616.799560546875,
      "height": 900,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a3",
